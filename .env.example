# Gate public futures REST base URLs. Keep multiple values as fallbacks, comma-separated.
GATE_API_BASE_URLS=https://fx-api.gateio.ws/api/v4,https://api.gateio.ws/api/v4

# Frontend API base URL. Setting this avoids relying on the Vite 5173 proxy.
VITE_API_BASE_URL=http://localhost:8787

# Gate public futures WebSocket URL.
VITE_GATE_WS_URL=wss://fx-ws.gateio.ws/v4/ws/usdt

# Optional Qwen config for AI overview and signal summaries.
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen3.5-plus
